generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL")
}

model SponsorshipHealthLog {
  id              String                  @id @default(cuid())
  sponsorshipId   String
  donorId         String
  registryChildId String
  healthStatus    SponsorshipHealthStatus
  reason          String?
  createdAt       DateTime                @default(now())
}

model SponsorshipPriorityQueue {
  id              String    @id @default(cuid())
  registryChildId String
  priorityLevel   String
  fundingGap      Int
  createdAt       DateTime  @default(now())
  resolvedAt      DateTime?
}

model ContactInquiry {
  id          String        @id @default(cuid())
  name        String
  email       String
  inquiryType InquiryType
  message     String
  status      InquiryStatus @default(NEW)
  deletedAt   DateTime?
  isArchived  Boolean       @default(false)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model Program {
  id             String            @id @default(cuid())
  name           String
  slug           String            @unique
  description    String
  location       String
  status         ProgramStatus     @default(ACTIVE)
  fundingGoal    Decimal
  fundingCurrent Decimal           @default(0)
  isLocked       Boolean           @default(false)
  isActive       Boolean           @default(true)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  schoolId       String?
  campaignId     String?
  children       Child[]
  donations      Donation[]
  posts          Post[]
  campaign       Campaign?         @relation(fields: [campaignId], references: [id])
  school         School?           @relation(fields: [schoolId], references: [id])
  snapshots      ProgramSnapshot[]
  sponsorships   Sponsorship[]
  stories        Story[]
}

model User {
  id                     String                  @id @default(cuid())
  email                  String                  @unique
  role                   Role                    @default(USER)
  name                   String?
  stripeCustomerId       String?
  country                String?
  preferredLanguage      String                  @default("en")
  isActive               Boolean                 @default(true)
  archivedAt             DateTime?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  emailVerified          DateTime?
  image                  String?
  lastImpactEmailSentAt  DateTime?
  emailSuppressed        Boolean                 @default(false)
  preferredCurrency      SupportedCurrency       @default(USD)
  preferredLocale        SupportedLocale         @default(EN)
  regionCode             String?
  timezone               String?
  accounts               Account[]
  auditLogs              AdminAuditLog[]
  corporateSponsor       CorporateSponsor?
  donations              Donation[]
  emailLogs              EmailLog[]
  emailPreferences       EmailPreferences?
  sessions               Session[]
  sponsorships           Sponsorship[]
  sponsorshipAssignments SponsorshipAssignment[]
}

model Child {
  id               String                 @id @default(cuid())
  name             String
  dob              DateTime
  bio              String
  story            String
  photoUrl         String
  status           ChildStatus            @default(WAITING)
  sponsorshipSlots Int                    @default(1)
  annualCost       Decimal
  gender           String
  region           String
  educationLevel   String
  moderationStatus ModerationStatus       @default(PENDING)
  visibilityScope  VisibilityScope        @default(PUBLIC)
  waitlistPosition Int?
  allocationMap    Json?
  isActive         Boolean                @default(true)
  archivedAt       DateTime?
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  schoolId         String
  programId        String?
  consentExpiry    DateTime?
  consentFlag      Boolean                @default(true)
  isAnonymized     Boolean                @default(false)
  usageScope       String?
  program          Program?               @relation(fields: [programId], references: [id])
  school           School                 @relation(fields: [schoolId], references: [id])
  updates          Post[]
  sponsorships     Sponsorship[]
  documents        VerificationDocument[]
}

model School {
  id                 String                 @id @default(cuid())
  name               String
  location           String
  capacity           Int
  establishedDate    DateTime
  contactPerson      String?
  verificationStatus VerificationStatus     @default(PENDING)
  partnerSince       DateTime               @default(now())
  isActive           Boolean                @default(true)
  archivedAt         DateTime?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  children           Child[]
  updates            Post[]
  programs           Program[]
  documents          VerificationDocument[]
}

model Sponsorship {
  id                   String            @id @default(cuid())
  startDate            DateTime          @default(now())
  endDate              DateTime?
  status               SponsorshipStatus @default(ACTIVE)
  monthlyAmount        Decimal
  stripeSubscriptionId String?
  tier                 SponsorshipTier   @default(FULL)
  userId               String
  programId            String
  childId              String?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  child                Child?            @relation(fields: [childId], references: [id])
  program              Program           @relation(fields: [programId], references: [id])
  user                 User              @relation(fields: [userId], references: [id])
}

model Donation {
  id                  String           @id @default(cuid())
  amount              Decimal
  currency            String           @default("USD")
  baseAmountUSD       Decimal?
  fxRate              Decimal?
  status              DonationStatus   @default(PENDING)
  stripePaymentId     String?          @unique
  type                DonationType
  fundType            DonationFundType @default(UNRESTRICTED)
  receiptUrl          String?
  invoiceNumber       String?
  allocationStatus    AllocationStatus @default(AUTOMATED)
  allocationTag       String?
  allocationBreakdown Json?
  userId              String
  programId           String?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  program             Program?         @relation(fields: [programId], references: [id])
  user                User             @relation(fields: [userId], references: [id])
}

model Post {
  id               String           @id @default(cuid())
  title            String
  content          String
  mediaUrl         String?
  moderationStatus ModerationStatus @default(PENDING)
  childId          String?
  schoolId         String?
  programId        String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  child            Child?           @relation(fields: [childId], references: [id])
  program          Program?         @relation(fields: [programId], references: [id])
  school           School?          @relation(fields: [schoolId], references: [id])
}

model AdminAuditLog {
  id           String      @id @default(cuid())
  action       AuditAction
  targetEntity String
  targetId     String?
  changes      Json?
  ipAddress    String?
  adminId      String
  createdAt    DateTime    @default(now())
  admin        User        @relation(fields: [adminId], references: [id])
}

model VerificationDocument {
  id          String             @id @default(cuid())
  entityType  EntityType
  documentUrl String
  status      VerificationStatus @default(PENDING)
  uploadedBy  String
  reviewedBy  String?
  childId     String?
  schoolId    String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  child       Child?             @relation(fields: [childId], references: [id])
  school      School?            @relation(fields: [schoolId], references: [id])
}

model MonthlySnapshot {
  id                String   @id @default(cuid())
  month             Int
  year              Int
  totalDonations    Decimal
  totalSponsorships Int
  activeChildren    Int
  churnRate         Decimal?
  createdAt         DateTime @default(now())

  @@unique([month, year])
}

model ProgramSnapshot {
  id               String   @id @default(cuid())
  month            Int
  year             Int
  fundsRaised      Decimal
  studentsImpacted Int
  programId        String
  createdAt        DateTime @default(now())
  program          Program  @relation(fields: [programId], references: [id])

  @@unique([programId, month, year])
}

model FailedWebhook {
  id         String   @id @default(cuid())
  eventId    String   @unique
  eventType  String
  payload    Json
  error      String?
  retryCount Int      @default(0)
  status     String   @default("PENDING")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Campaign {
  id             String         @id @default(cuid())
  title          String
  slug           String         @unique
  urgencyLevel   UrgencyLevel   @default(LOW)
  status         CampaignStatus @default(ACTIVE)
  fundingGoal    Decimal
  fundingCurrent Decimal        @default(0)
  deadline       DateTime?
  heroMedia      String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  programs       Program[]
}

model Story {
  id          String           @id @default(cuid())
  title       String
  region      String
  narrative   String
  mediaUrl    String?
  publishDate DateTime         @default(now())
  status      ModerationStatus @default(PENDING)
  programId   String
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  program     Program          @relation(fields: [programId], references: [id])
}

model Referral {
  id              String         @id @default(cuid())
  referrerName    String
  email           String
  childLocation   String
  educationStatus String
  urgencyLevel    UrgencyLevel   @default(LOW)
  notes           String?
  status          ReferralStatus @default(PENDING)
  deletedAt       DateTime?
  isArchived      Boolean        @default(false)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model RegistryChild {
  id                       String                           @id @default(cuid())
  displayName              String
  age                      Int
  region                   String
  educationLevel           String
  sponsorshipNeededMonthly Decimal
  status                   ChildStatus                      @default(WAITING)
  privacyMode              VisibilityScope                  @default(PUBLIC)
  safeguardingConsent      Boolean                          @default(false)
  avatarIllustrationUrl    String?
  caseNotes                String?
  maxSponsors              Int                              @default(1)
  referralId               String?                          @unique
  createdByAdminId         String
  lastReviewedAt           DateTime?
  safeguardingReviewStatus SafeguardingReviewStatus         @default(PENDING)
  deletedAt                DateTime?
  isArchived               Boolean                          @default(false)
  createdAt                DateTime                         @default(now())
  updatedAt                DateTime                         @updatedAt
  story                    String?
  corporateAllocations     CorporateSponsorshipAllocation[]
  milestones               ImpactMilestone[]
  progressReports          ProgressReport[]
  assignments              SponsorshipAssignment[]
}

model SponsorshipAssignment {
  id              String                      @id @default(cuid())
  donorId         String
  registryChildId String
  startedAt       DateTime                    @default(now())
  endedAt         DateTime?
  status          SponsorshipAssignmentStatus @default(ACTIVE)
  donor           User                        @relation(fields: [donorId], references: [id])
  registryChild   RegistryChild               @relation(fields: [registryChildId], references: [id])
}

model AdminAccessLog {
  id            String   @id @default(cuid())
  adminId       String
  routeAccessed String
  timestamp     DateTime @default(now())
  ipAddress     String?
}

model AdminActionLog {
  id            String   @id @default(cuid())
  adminId       String
  actionType    String
  targetEntity  String
  targetId      String
  previousValue String?
  newValue      String?
  timestamp     DateTime @default(now())
}

model ImpactStory {
  id                 String      @id @default(cuid())
  title              String
  content            String
  imageUrl           String?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  consentDocumentUrl String?
  consentExpiry      DateTime?
  engagementScore    Float       @default(0)
  guardianConsent    Boolean     @default(false)
  publishAt          DateTime?
  status             StoryStatus @default(DRAFT)
  viewCount          Int         @default(0)
}

model ProgressReport {
  id                       String                   @id @default(cuid())
  registryChildId          String
  reportingPeriod          String
  academicPerformance      String
  attendanceRate           Float?
  teacherFeedback          String?
  wellbeingNotes           String?
  reportDocumentUrl        String?
  verificationStatus       ReportVerificationStatus @default(PENDING)
  verifiedByAdminId        String?
  verifiedAt               DateTime?
  guardianConsentConfirmed Boolean                  @default(false)
  consentDocumentUrl       String?
  publishAt                DateTime?
  riskScore                ProgressRiskScore        @default(STABLE)
  createdByAdminId         String
  createdAt                DateTime                 @default(now())
  registryChild            RegistryChild            @relation(fields: [registryChildId], references: [id])
}

model ImpactMilestone {
  id               String        @id @default(cuid())
  registryChildId  String
  milestoneType    MilestoneType @default(ENROLLED)
  description      String
  achievedAt       DateTime
  createdByAdminId String
  createdAt        DateTime      @default(now())
  registryChild    RegistryChild @relation(fields: [registryChildId], references: [id])
}

model CorporateSponsor {
  id                  String                           @id @default(cuid())
  organizationName    String
  contactPersonName   String
  contactEmail        String
  contactPhone        String?
  headquartersCountry String
  fundingModel        FundingModel                     @default(SLOT_BASED)
  sponsorshipCapacity Int
  contractStartDate   DateTime                         @default(now())
  contractEndDate     DateTime?
  status              CorporateStatus                  @default(ACTIVE)
  userId              String?                          @unique
  createdAt           DateTime                         @default(now())
  updatedAt           DateTime                         @updatedAt
  impactSnapshots     CSRImpactSnapshot[]
  user                User?                            @relation(fields: [userId], references: [id])
  allocations         CorporateSponsorshipAllocation[]
}

model CorporateSponsorshipAllocation {
  id                 String                    @id @default(cuid())
  corporateSponsorId String
  registryChildId    String
  allocatedSlots     Int                       @default(1)
  filledSlots        Int                       @default(0)
  allocationStatus   CorporateAllocationStatus @default(OPEN)
  revokedAt          DateTime?
  revokedReason      String?
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt
  corporateSponsor   CorporateSponsor          @relation(fields: [corporateSponsorId], references: [id])
  registryChild      RegistryChild             @relation(fields: [registryChildId], references: [id])
}

model CSRImpactSnapshot {
  id                         String           @id @default(cuid())
  corporateSponsorId         String
  childrenSponsored          Int
  activeSponsorships         Int
  educationProgramsSupported Int
  generatedAt                DateTime         @default(now())
  corporateSponsor           CorporateSponsor @relation(fields: [corporateSponsorId], references: [id])
}

model EmailPreferences {
  id                   String   @id @default(cuid())
  userId               String   @unique
  receiveImpactUpdates Boolean  @default(true)
  receiveMilestones    Boolean  @default(true)
  receiveRiskAlerts    Boolean  @default(true)
  receiveCSRReports    Boolean  @default(true)
  updatedAt            DateTime @updatedAt
  user                 User     @relation(fields: [userId], references: [id])
}

model EmailLog {
  id              String         @id @default(cuid())
  eventId         String         @unique
  recipientId     String
  recipientType   RecipientType
  eventType       EmailEventType
  templateVersion String
  sentAt          DateTime?
  deliveryStatus  DeliveryStatus @default(PENDING)
  errorMessage    String?
  createdAt       DateTime       @default(now())
  user            User           @relation(fields: [recipientId], references: [id], onDelete: Cascade)
}

model ExchangeRateSnapshot {
  id             String            @id @default(cuid())
  baseCurrency   SupportedCurrency
  targetCurrency SupportedCurrency
  rate           Float
  capturedAt     DateTime          @default(now())
}

enum Role {
  USER
  ADMIN
  FIELD_PARTNER
  FINANCE
}

enum ChildStatus {
  WAITING
  SPONSORED
  GRADUATED
}

enum ModerationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum VisibilityScope {
  PUBLIC
  SPONSOR_ONLY
}

enum VerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum SponsorshipStatus {
  ACTIVE
  CANCELLED
  PAST_DUE
}

enum SponsorshipTier {
  FULL
  PARTIAL
}

enum DonationType {
  ONE_TIME
  RECURRING_MONTHLY
}

enum DonationFundType {
  RESTRICTED
  UNRESTRICTED
}

enum AllocationStatus {
  AUTOMATED
  PENDING_APPROVAL
  APPROVED
}

enum DonationStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  EXPORT
  LOGIN
}

enum UrgencyLevel {
  LOW
  HIGH
  CRITICAL
}

enum CampaignStatus {
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum EntityType {
  CHILD
  SCHOOL
  DOCUMENT
  PROGRAM
}

enum ProgramStatus {
  ACTIVE
  FULLY_FUNDED
  ARCHIVED
}

enum ReferralStatus {
  PENDING
  UNDER_REVIEW
  APPROVED
  REJECTED
  ARCHIVED
}

enum StoryStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum SafeguardingReviewStatus {
  PENDING
  VERIFIED
  FLAGGED
}

enum SponsorshipAssignmentStatus {
  ACTIVE
  PAUSED
  ENDED
}

enum InquiryType {
  GENERAL
  SPONSORSHIP
  REFER_CHILD
  REQUEST_ASSISTANCE
  PARTNERSHIP
  MEDIA
}

enum InquiryStatus {
  NEW
  IN_PROGRESS
  RESOLVED
  ARCHIVED
}

enum SponsorshipHealthStatus {
  HEALTHY
  AT_RISK
  PAYMENT_FAILED
  ENDED
}

enum MilestoneType {
  ENROLLED
  GRADE_PROMOTED
  EXAM_PASSED
  SCHOLARSHIP_AWARDED
  GRADUATED
}

enum ReportVerificationStatus {
  PENDING
  VERIFIED
  FLAGGED
}

enum ProgressRiskScore {
  STABLE
  MONITOR
  INTERVENTION_REQUIRED
}

enum CorporateStatus {
  ACTIVE
  PAUSED
  ENDED
}

enum FundingModel {
  SLOT_BASED
  POOL_BASED
}

enum CorporateAllocationStatus {
  OPEN
  PARTIALLY_FILLED
  FULLY_ALLOCATED
}

enum RecipientType {
  DONOR
  CORPORATE
  ADMIN
}

enum EmailEventType {
  REPORT_VERIFIED
  MILESTONE_LOGGED
  RISK_SCORE_CHANGED
  SPONSOR_COOLING
  SPONSOR_CHURNED
  CORPORATE_RENEWAL_WINDOW
  CONTRACT_EXPIRY_WARNING
  CSR_SNAPSHOT_READY
  GRADUATED
}

enum DeliveryStatus {
  PENDING
  SENT
  FAILED
  BOUNCED
}

enum SupportedLocale {
  EN
  FR
  ES
  HI
}

enum SupportedCurrency {
  USD
  CAD
  INR
  EUR
}
